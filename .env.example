# Supabase (self-hosted via supabase-docker/)
# Start with: cd supabase-docker && docker compose up -d
NUXT_PUBLIC_SUPABASE_URL=https://api.yourdomain.com
NUXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
NUXT_SUPABASE_SERVICE_KEY=sb_secret_...

# Full app URL — used in email confirmation links
NUXT_SITE_URL=https://yourdomain.com

# Optional: override where users land after email verification (defaults to /ops/confirm)
# Must be listed in ADDITIONAL_REDIRECT_URLS in supabase-docker/.env
NUXT_PUBLIC_EMAIL_VERIFIED_REDIRECT_URL=https://yourdomain.com/ops/confirm

# Postmark (transactional email)
NUXT_POSTMARK_TOKEN=your-server-token
NUXT_POSTMARK_FROM_EMAIL=noreply@yourdomain.com

DOMAIN=yourdomain.com
